{% extends 'base.html.twig' %}

{% block title %}Materiel{% endblock %}

{% block body %}
    <h1>Materiel</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ materiel.id }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ materiel.nom }}</td>
            </tr>
            <tr>
                <th>Categorie</th>
                <td>{{ materiel.categorie }}</td>
            </tr>
            <tr>
                <th>Reference</th>
                <td>{{ materiel.reference }}</td>
            </tr>
            <tr>
                <th>Date_achat</th>
                <td>{{ materiel.dateAchat ? materiel.dateAchat|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>Disponible</th>
                <td>{{ materiel.disponible ? 'Yes' : 'No' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_materiel_index') }}">back to list</a>

    <a href="{{ path('app_materiel_edit', {'id': materiel.id}) }}">edit</a>

    {{ include('materiel/_delete_form.html.twig') }}
{% endblock %}
